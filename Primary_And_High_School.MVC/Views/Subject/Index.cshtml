@model List<Primary_And_High_School.Domain.Subject>

<h2>Subjects</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Add Subject</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Subject Name</th>
            <th>Credits</th>
            <th>Student</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var subject in Model)
        {
            <tr>
                <td>@subject.SubjectName</td>
                <td>@subject.NumCredits</td>
                <td>@subject.StudentNumber</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@subject.SubjectId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@subject.SubjectId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>